{
  "name": "opencode-discord-bridge",
  "version": "1.0.0",
  "description": "Bridge between Discord and OpenCode CLI for remote development sessions",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest",
    "test:ci": "vitest run",
    "install-service": "powershell -ExecutionPolicy Bypass -File scripts/install-service.ps1"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.5",
    "strip-ansi": "^7.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "undici": "^6.24.1"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}

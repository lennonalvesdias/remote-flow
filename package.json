{
  "name": "remote-flow",
  "version": "1.0.0",
  "license": "MIT",
  "description": "RemoteFlow — a ponte entre o seu ambiente de desenvolvimento local e o Discord.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest",
    "test:unit": "vitest run --exclude 'tests/integration/**'",
    "test:integration": "vitest run tests/integration",
    "test:ci": "vitest run",
    "install-service": "powershell -ExecutionPolicy Bypass -File scripts/install-service.ps1",
    "kill-port": "powershell -ExecutionPolicy Bypass -File scripts/kill-port.ps1",
    "whisper": ".venv-whisper\\Scripts\\python whisper_server/server.py"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.5",
    "octokit": "^5.0.5",
    "strip-ansi": "^7.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "undici": "^6.24.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "vitest": "^4.1.0"
  }
}

# ========================================
# RemoteFlow — Configuração
# ========================================

# Token do seu Bot Discord
# Obtenha em: https://discord.com/developers/applications
DISCORD_TOKEN=seu_token_aqui

# ID do servidor Discord onde o bot vai operar
# Clique com botão direito no servidor > "Copiar ID do servidor"
DISCORD_GUILD_ID=seu_guild_id_aqui

# Client ID do bot (Application ID no Discord Developer Portal)
# Necessário apenas na primeira execução para registrar os slash commands
# DISCORD_CLIENT_ID=seu_client_id_aqui

# ID do canal onde os comandos serão aceitos (opcional)
# Mensagens fora deste canal serão ignoradas
# DISCORD_ALLOWED_CHANNEL_ID=

# Caminho base dos seus projetos no Windows
# O bot vai listar subpastas como projetos disponíveis
PROJECTS_BASE_PATH=C:\Users\SeuUsuario\projetos

# Caminho ou nome do binário opencode (usado para iniciar 'opencode serve')
# Use "opencode" se estiver no PATH, ou o caminho completo
# OPENCODE_BIN=opencode

# Porta base para os servidores opencode serve (padrão: 4100)
# Cada projeto usa uma porta incremental a partir desta base
OPENCODE_BASE_PORT=4100

# Porta base do servidor plannotator por sessão opencode (default: OPENCODE_BASE_PORT + 1000)
# Cada servidor opencode recebe uma porta plannotator dedicada a partir deste valor
# PLANNOTATOR_BASE_PORT=5100

# Intervalo de polling para detectar plano pronto no plannotator (ms)
# PLAN_POLL_INTERVAL_MS=3000

# Limite de caracteres por mensagem Discord (máximo 2000)
DISCORD_MSG_LIMIT=1900

# Intervalo em ms para atualizar mensagem de streaming (evita rate limit)
STREAM_UPDATE_INTERVAL=1500

# IDs de usuários Discord autorizados a usar o bot (separados por vírgula)
# Deixe vazio para permitir todos no servidor
ALLOWED_USER_IDS=seu_user_id_aqui

# Permitir que qualquer usuário autorizado interaja com qualquer sessão
# Por padrão, apenas o criador da sessão pode controlá-la
# ALLOW_SHARED_SESSIONS=false
# Se true, permite que outros usuários usem sessões criadas por outro usuário
# ENABLE_DM_NOTIFICATIONS=false

# Máximo de sessões ativas por usuário (padrão: 3)
# MAX_SESSIONS_PER_USER=3

# Timeout de inatividade por sessão em ms (padrão: 30 min = 1800000)
# Sessões sem atividade serão encerradas automaticamente
# SESSION_TIMEOUT_MS=1800000

# Porta do endpoint de health check (padrão: 9090)
# Acessível em http://localhost:9090/health
# HEALTH_PORT=9090

# Interface de rede do health check (padrão: 127.0.0.1 — apenas loopback)
# Defina como 0.0.0.0 para expor na rede (ex: para scraping Prometheus externo)
# HEALTH_HOST=127.0.0.1

# ─── Desenvolvimento ──────────────────────────────────────────────────────────

# Ativa logs detalhados de debug (pipeline de sessões, flush, Discord API)
# Recomendado durante desenvolvimento e diagnóstico de problemas
# DEBUG=true

# Diretório de comandos customizados do opencode (default: ~/.config/opencode/command)
# OPENCODE_COMMANDS_PATH=C:\Users\seu-usuario\.config\opencode\command

# Caminho para o arquivo de persistência de sessões (padrão: ~/.remote-flow/data.json)
# PERSISTENCE_PATH=C:\Users\seuusuario\.remote-flow\data.json

# ─── Modelos de IA ────────────────────────────────────────────────────────────

# Lista de modelos disponíveis para seleção via autocomplete nos comandos /plan e /build
# Separe múltiplos modelos por vírgula, sem espaços
# AVAILABLE_MODELS=anthropic/claude-sonnet-4-5,openai/gpt-4o,google/gemini-2.0-flash

# Modelo de IA padrão ao iniciar uma sessão (vazio = usa o padrão configurado no opencode)
# DEFAULT_MODEL=anthropic/claude-sonnet-4-5

# ─── Auditoria ────────────────────────────────────────────────────────────────

# Caminho do arquivo de auditoria NDJSON (padrão: ~/.remote-flow/audit.ndjson)
# AUDIT_LOG_PATH=

# Tamanho máximo do arquivo de auditoria antes de rotacionar (padrão: 50 MB)
# O arquivo atual é renomeado para .1 quando o limite é atingido.
# AUDIT_LOG_MAX_BYTES=52428800

# Tamanho máximo do arquivo de log da aplicação antes de rotacionar (padrão: 50 MB)
# APP_LOG_MAX_BYTES=52428800

# ─── GitHub ───────────────────────────────────────────────────────────────────

# Personal Access Token do GitHub para integração com repositórios
# Escopos necessários: repo (para criar PRs e reviews)
# Gere em: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_seu_token_aqui

# Fallback de owner/repo quando não detectável via git remote (opcional)
# Use quando o projeto local não tem remote "origin" configurado
# GITHUB_DEFAULT_OWNER=minha-org
# GITHUB_DEFAULT_REPO=meu-repo

# Nome e email do autor para commits automáticos do bot
# GIT_AUTHOR_NAME=RemoteFlow Bot
# GIT_AUTHOR_EMAIL=bot@remote-flow.local

# ─── Transcrição de Voz ──────────────────────────────────────────────────────

# Provider de transcrição de mensagens de voz
# 'local' requer o whisper_server Python rodando localmente
# 'openai' e 'groq' requerem TRANSCRIPTION_API_KEY
# TRANSCRIPTION_PROVIDER=local

# URL do Whisper Server local (padrão: http://127.0.0.1:8765)
# WHISPER_URL=http://127.0.0.1:8765

# Interface de rede para o Whisper Server (padrão: 127.0.0.1 = somente local)
# WHISPER_HOST=127.0.0.1

# API key para providers externos (OpenAI ou Groq)
# TRANSCRIPTION_API_KEY=sk-...

# Modelo para APIs externas (padrão: whisper-1)
# TRANSCRIPTION_API_MODEL=whisper-1

# Idioma forçado para transcrição — evita detecção automática (padrão: pt)
# Usado tanto pelo Whisper Server local (via env var do processo Python) quanto
# pelos providers externos (OpenAI e Groq), que o enviam na requisição HTTP.
# WHISPER_LANGUAGE=pt

# Duração máxima de áudio aceita em segundos (padrão: 300 = 5 min)
# VOICE_MAX_DURATION_SECS=300

# Limite diário de segundos de áudio transcrito via API externa (0 = sem limite)
# Aplica-se apenas a providers 'openai' e 'groq'. Reseta à meia-noite.
# Atenção: o contador é mantido em memória e volta a zero ao reiniciar o processo.
# Exemplo: 3600 = no máximo 1 hora de áudio/dia
# TRANSCRIPTION_DAILY_LIMIT_SECS=0

# Exibir transcrição na thread antes de enviar ao OpenCode (padrão: true)
# VOICE_SHOW_TRANSCRIPT=true

# Timeout em ms para download do áudio da CDN do Discord (padrão: 30s)
# Aumente se a CDN do Discord estiver lenta ou para arquivos maiores
# VOICE_CDN_DOWNLOAD_TIMEOUT_MS=30000

# Timeout em ms para a chamada de transcrição ao Whisper Server (padrão: 120s)
# Deve ser alto o suficiente para cobrir cold-start de GPU (compilação de kernels CUDA)
# na primeira inferência real. Reduza em hardware mais rápido.
# WHISPER_TRANSCRIPTION_TIMEOUT_MS=120000
